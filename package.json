{
  "name": "sketchforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev apps/web",
    "build": "next build apps/web",
    "export": "set STATIC_EXPORT=true&& next build apps/web",
    "start": "next start apps/web",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf": "vitest run --config vitest.perf.config.ts --reporter verbose",
    "ci": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/three": "^0.184.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "manifold-3d": "^3.5.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8",
    "three": "^0.184.0",
    "three-bvh-csg": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
