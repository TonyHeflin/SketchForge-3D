{
  "name": "sketchforge",
  "version": "0.6.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "copy:occt": "node scripts/copy-occt-wasm.mjs",
    "predev": "npm run copy:occt",
    "dev": "next dev apps/web",
    "prebuild": "npm run copy:occt",
    "build": "next build apps/web",
    "export": "cross-env STATIC_EXPORT=true next build apps/web && node scripts/verify-static-worker-assets.mjs",
    "verify:static-worker-assets": "node scripts/verify-static-worker-assets.mjs",
    "start": "next start apps/web",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:e2e": "vitest run --config tests/vitest.e2e.config.ts",
    "perf": "vitest run --config tests/vitest.perf.config.ts --reporter verbose",
    "ci": "npm run typecheck && npm run test",
    "docker:build": "docker build -f deploy/docker/Dockerfile -t sketchforge:local .",
    "docker:run": "docker run --rm -p 3000:80 sketchforge:local",
    "docker:up": "docker compose -f deploy/docker/compose.yaml up --build -d",
    "docker:down": "docker compose -f deploy/docker/compose.yaml down",
    "mcp:sketchforge": "node scripts/sketchforge-mcp-server.mjs",
    "desktop:typecheck": "tsc -p desktop/tsconfig.json --noEmit",
    "desktop:compile": "tsc -p desktop/tsconfig.json",
    "desktop:dev": "npm run desktop:compile && cross-env SKETCHFORGE_DESKTOP_DEV_URL=http://localhost:3000 electron desktop/dist/main.js",
    "desktop:build": "npm run export && npm run desktop:compile",
    "desktop:package": "npm run desktop:build && electron-builder --config desktop/electron-builder.yml"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/three": "^0.184.1",
    "brepjs": "^18.118.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "manifold-3d": "^3.5.0",
    "next": "^15.3.2",
    "occt-wasm": "^3.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8",
    "three": "^0.184.0",
    "three-bvh-csg": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "main": "desktop/dist/main.js"
}
